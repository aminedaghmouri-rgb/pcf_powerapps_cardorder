{
  "name": "pcf-project",
  "version": "1.0.39",
  "description": "Project containing your PowerApps Component Framework (PCF) control.",
  "scripts": {
    "build": "pcf-scripts build",
    "clean": "pcf-scripts clean",
    "deploy:push": "npm run clean && npm run build && npm run pp:push",
    "deploy:zip": "npm run clean && npm run build && npm run package:solution",
    "lint": "pcf-scripts lint",
    "lint:fix": "pcf-scripts lint fix",
    "package:solution": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/package-solution.ps1",
    "pp:auth:list": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/pac.ps1 auth list",
    "pp:push": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/pac.ps1 pcf push --publisher-prefix sa",
    "rebuild": "pcf-scripts rebuild",
    "start": "pcf-scripts start",
    "start:watch": "pcf-scripts start watch",
    "refreshTypes": "pcf-scripts refreshTypes"
  },
  "dependencies": {
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@microsoft/eslint-plugin-power-apps": "^0.2.51",
    "@types/node": "^18.19.86",
    "@types/powerapps-component-framework": "^1.3.16",
    "eslint-plugin-promise": "^7.1.0",
    "globals": "^15.15.0",
    "pcf-scripts": "^1",
    "pcf-start": "^1",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.44.0"
  }
}
